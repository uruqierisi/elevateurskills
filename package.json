{
  "name": "elevateurskills",
  "version": "0.1.0",
  "description": "Open-source multi-agent AI coding pipeline. Give it a software request; specialist agents plan, architect, build, test, review, and package a runnable project.",
  "type": "module",
  "license": "Apache-2.0",
  "bin": {
    "elevateurskills": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "smoke:llm": "tsx scripts/smoke-llm.ts",
    "smoke:loop": "tsx scripts/smoke-loop.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
