{
  "name": "elevateurskills",
  "version": "0.1.0",
  "description": "Open-source multi-agent AI coding pipeline. Give it a software request; specialist agents plan, architect, build, test, review, and package a runnable project.",
  "type": "module",
  "license": "Apache-2.0",
  "bin": {
    "elevateurskills": "./dist/cli.js"
  },
  "files": [
    "dist",
    "agents",
    "sandbox",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "postbuild": "node scripts/postbuild.mjs",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "smoke:llm": "tsx scripts/smoke-llm.ts",
    "smoke:loop": "tsx scripts/smoke-loop.ts",
    "smoke:tui": "tsx scripts/smoke-tui.tsx",
    "smoke:ui": "tsx scripts/smoke-ui.ts",
    "smoke:sandbox": "tsx scripts/smoke-sandbox.ts",
    "smoke:limits": "tsx scripts/smoke-limits.ts",
    "test": "npm run typecheck && npm run smoke:ui && npm run smoke:tui && npm run smoke:loop && npm run smoke:limits && npm run smoke:sandbox"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.8",
    "@ai-sdk/deepseek": "^3.0.5",
    "@ai-sdk/openai": "^4.0.8",
    "ai": "^7.0.16",
    "chalk": "^5.6.2",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "ink": "^5.2.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.31",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
