# Pick ONE active model: provider/model
# provider ∈ deepseek | openai | anthropic
ELEVATE_LLM=deepseek/deepseek-chat

# Set the key for the provider you chose (only that one is required)
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: override base URL for local / OpenAI-compatible endpoints
# LLM_API_BASE=

# Optional: per-agent circuit-breaker budgets (CLI flags override these)
# MAX_AGENT_TOKENS=500000
# MAX_AGENT_ITERATIONS=50

# Sandbox outbound internet (Docker backend). Enabled by default so agents can
# run npm install / npx prisma generate. Set to false to fully isolate the
# sandbox (no outbound; a Postgres sidecar network, if any, is still reachable).
# SANDBOX_INTERNET=true

# DNS servers injected into sandbox containers (comma-separated). Defaults to
# 8.8.8.8,1.1.1.1 as a fallback for hosts (e.g. WSL2) whose resolv.conf points
# at a stub resolver Docker can't reach. Set to "none" to use Docker's own DNS.
# SANDBOX_DNS=8.8.8.8,1.1.1.1
